  "item": [
    {
      "name": "Films",
      "item": [
        {
          "name": "List films (baseline)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('List envelope has contentRange/results', function () {",
                  "  pm.expect(json).to.be.an('object');",
                  "  pm.expect(json).to.have.property('contentRange');",
                  "  pm.expect(json.contentRange).to.be.a('string');",
                  "  pm.expect(json).to.have.property('results');",
                  "  pm.expect(json.results).to.be.an('array');",
                  "  pm.expect(json.results.length).to.be.at.most(10);",
                  "});",
                  "pm.test('Film items have filmId/title/releaseDate', function(){",
                  "  json.results.forEach(f => {",
                  "    pm.expect(f).to.have.property('filmId');",
                  "    pm.expect(String(f.filmId)).to.match(/^[0-9a-fA-F-]{36}$/);",
                  "    pm.expect(f).to.have.property('title');",
                  "    pm.expect(f.title).to.be.a('string');",
                  "    if (f.releaseDate !== undefined) pm.expect(f.releaseDate).to.match(/^\\d{4}-\\d{2}-\\d{2}$/);",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{hostname}}/v2/films",
              "host": ["{{hostname}}"],
              "path": ["v2", "films"]
            }
          },
          "response": []
        },
        {
          "name": "Find filmId via filter (title contains Hope*)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('At least one result', () => pm.expect(json.results.length).to.be.at.least(1));",
                  "pm.environment.set('filmId', String(json.results[0].filmId));",
                  "pm.test('Stored filmId', () => pm.expect(pm.environment.get('filmId')).to.match(/^[0-9a-fA-F-]{36}$/));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{hostname}}/v2/films?title=Hope*",
              "host": ["{{hostname}}"],
              "path": ["v2", "films"],
              "query": [{"key":"title","value":"Hope*"}]
            }
          },
          "response": []
        },
        {
          "name": "Get film by derived filmId",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('filmId exists', function(){ pm.expect(pm.environment.get('filmId')).to.match(/^[0-9a-fA-F-]{36}$/); });",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const f = pm.response.json();",
                  "pm.test('filmId matches', function(){ pm.expect(String(f.filmId)).to.equal(String(pm.environment.get('filmId'))); });",
                  "pm.test('Film has required fields', function(){",
                  "  pm.expect(f.title).to.be.a('string');",
                  "  pm.expect(f.episode).to.be.a('number');",
                  "  pm.expect(f.createdDateTime).to.match(/Z$/);",
                  "  pm.expect(f.updatedDateTime).to.match(/Z$/);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{hostname}}/v2/films/{{filmId}}",
              "host": ["{{hostname}}"],
              "path": ["v2", "films", "{{filmId}}"]
            }
          },
          "response": []
        }
      ]
    },
