        {
          "name": "Find characterId via filter (name contains Luke*)",
          "event": [
            {
              "listen": "test",
              "script": {"type":"text/javascript","exec":[
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('At least one result', () => pm.expect(json.results.length).to.be.at.least(1));",
                "pm.test('All names contain luke', function(){ json.results.forEach(c => pm.expect(String(c.name).toLowerCase()).to.include('luke')); });",
                "const luke = json.results[0];",
                "pm.environment.set('characterId', String(luke.characterId));",
                "if (luke.homeworldPlanetId) pm.environment.set('planetId', String(luke.homeworldPlanetId));",
                "if (luke.speciesId) pm.environment.set('speciesId', String(luke.speciesId));",
                "pm.test('Stored characterId', () => pm.expect(pm.environment.get('characterId')).to.match(/^[0-9a-fA-F-]{36}$/));"
              ]}
            }
          ],
          "request": {"method":"GET","header":[],"url":{"raw":"{{hostname}}/v2/characters?name=Luke*","host":["{{hostname}}"],"path":["v2","characters"],"query":[{"key":"name","value":"Luke*"}]}} ,
          "response": []
        },
        {
          "name": "Get character by derived characterId",
          "event": [
            {"listen":"test","script":{"type":"text/javascript","exec":[
              "pm.test('characterId exists', function(){ pm.expect(pm.environment.get('characterId')).to.match(/^[0-9a-fA-F-]{36}$/); });",
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const c = pm.response.json();",
              "pm.test('characterId matches', function(){ pm.expect(String(c.characterId)).to.equal(String(pm.environment.get('characterId'))); });",
              "pm.test('Character has required fields', function(){",
              "  pm.expect(c.name).to.be.a('string');",
              "  pm.expect(c.createdDateTime).to.match(/Z$/);",
              "  pm.expect(c.updatedDateTime).to.match(/Z$/);",
              "});",
              "pm.test('Linked ids have expected shapes', function(){",
              "  if (c.homeworldPlanetId) pm.expect(String(c.homeworldPlanetId)).to.match(/^[0-9a-fA-F-]{36}$/);",
              "  if (c.speciesId) pm.expect(String(c.speciesId)).to.match(/^[0-9a-fA-F-]{36}$/);",
              "  ['filmIds','starshipIds','vehicleIds'].forEach(k => {",
              "    if (c[k]) { pm.expect(c[k]).to.be.an('array'); c[k].forEach(id => pm.expect(String(id)).to.match(/^[0-9a-fA-F-]{36}$/)); }",
              "  });",
              "});"
            ]}}
          ],
          "request": {"method":"GET","header":[],"url":{"raw":"{{hostname}}/v2/characters/{{characterId}}","host":["{{hostname}}"],"path":["v2","characters","{{characterId}}"]}},
          "response": []
        }
