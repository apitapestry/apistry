    {
      "name": "Films",
      "item": [
        {
          "name": "List films (baseline)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('List envelope has count/contentRange/results', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.be.an('object');",
                  "  pm.expect(json).to.have.property('count');",
                  "  pm.expect(json.count).to.be.a('number');",
                  "  pm.expect(json).to.have.property('contentRange');",
                  "  pm.expect(json.contentRange).to.be.a('string');",
                  "  pm.expect(json).to.have.property('results');",
                  "  pm.expect(json.results).to.be.an('array');",
                  "  pm.expect(json.results.length).to.be.at.least(0);",
                  "  pm.expect(json.results.length).to.be.at.most(10);",
                  "});",
                  "pm.test('Count is >= results.length', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.count).to.be.at.least(json.results.length);",
                  "});",
                  "pm.test('contentRange matches count', function () {",
                  "  const json = pm.response.json();",
                  "  const m = /^items\\s+(\\d+)-(\\d+)\\/(\\d+)$/.exec(json.contentRange || '');",
                  "  pm.expect(m, 'contentRange format items {start}-{end}/{total}').to.not.equal(null);",
                  "  const total = Number(m[3]);",
                  "  pm.expect(total).to.equal(json.count);",
                  "});",
                  "pm.test('Film items have required fields', function () {",
                  "  const json = pm.response.json();",
                  "  json.results.forEach(function (f) {",
                  "    pm.expect(f).to.have.property('id');",
                  "    pm.expect(String(f.id)).to.match(/^\\d+$/);",
                  "    pm.expect(f).to.have.property('title');",
                  "    pm.expect(f.title).to.be.a('string');",
                  "    pm.expect(f).to.have.property('release_date');",
                  "    pm.expect(f.release_date).to.match(/^\\d{4}-\\d{2}-\\d{2}$/);",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{hostname}}/v1/films",
              "host": [
                "{{hostname}}"
              ],
              "path": [
