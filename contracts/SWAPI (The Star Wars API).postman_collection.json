                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('results length <= limit', function () {",
                  "  pm.expect(json.results.length).to.be.at.most(2);",
                  "});",
                  "pm.test('contentRange end-start+1 equals results length when results non-empty', function () {",
                  "  const m = /^items\\s+(\\d+)-(\\d+)\\/(\\d+)$/.exec(json.contentRange || '');",
                  "  pm.expect(m).to.not.equal(null);",
                  "  const start = Number(m[1]);",
                  "  const end = Number(m[2]);",
                  "  if (json.results.length > 0) pm.expect(end - start + 1).to.equal(json.results.length);",
                  "});"
                ]
              }
            }
