{
  "name": "apistry",
  "version": "0.0.0",
  "description": "APIstry - Provide functional APIs directly from OpenAPI specification",
  "homepage": "https://www.apistry.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apitapestry/apistry.git"
  },
  "bugs": {
    "url": "https://github.com/apitapestry/apistry/issues"
  },
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "apistry": "dist/apistry.js"
  },
  "main": "dist/apistry.js",
  "files": [
    "dist/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && node scripts/build.mjs",
    "build:lambda": "npm run build && node scripts/package-lambda.mjs",
    "test": "vitest run --config tests/vitest.config.js",
    "lint": "eslint . --ext .mjs,.js"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@fastify/aws-lambda": "^6.4.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "bad-words": "^4.0.0",
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0",
    "currency-codes": "^2.2.0",
    "fast-csv": "^5.0.7",
    "fast-luhn": "^2.0.2",
    "fastify": "^5.9.0",
    "fastify-openapi-glue": "^4.11.3",
    "i18n-iso-countries": "^7.14.0",
    "js-yaml": "^5.2.1",
    "jsonpath-plus": "^10.4.0",
    "libphonenumber-js": "^1.13.8",
    "mongodb": "^7.4.0",
    "pg": "^8.22.0",
    "pino-pretty": "^13.1.2",
    "pluralize": "^8.0.0",
    "postal-codes-js": "^2.5.2",
    "uuid": "^14.0.1"
  },
  "overrides": {
    "sockjs": {
      "uuid": "^11.1.0"
    }
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.9",
    "adm-zip": "^0.5.18",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "glob": "^13.0.6",
    "vitest": "^4.1.9"
  }
}
